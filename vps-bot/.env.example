# ===== Lovable Cloud (obrigatório) =====
# URL da edge function ifood-bot-control (não muda)
LOVABLE_FN_URL=https://yxmirlnvrrintrvicqic.supabase.co/functions/v1/ifood-bot-control
# Edge function ingestão de pedidos
LOVABLE_INGEST_URL=https://yxmirlnvrrintrvicqic.supabase.co/functions/v1/external-orders-ingest
# Edge function bridge do WhatsApp
LOVABLE_WA_BRIDGE_URL=https://yxmirlnvrrintrvicqic.supabase.co/functions/v1/wa-vps-bridge

# Token compartilhado — MESMO valor que você salvou em IFOOD_BOT_TOKEN no Lovable
BOT_TOKEN=cole_aqui_o_mesmo_token_que_esta_no_lovable

# ===== iFood Bot (Playwright) =====
POLL_INTERVAL_MS=20000
HEADLESS=true
SLOW_MO=0
IFOOD_PORTAL_URL=https://portal.ifood.com.br

# Proxy residencial BR (recomendado se Cloudflare bloquear IP da VPS)
HTTP_PROXY=
HTTPS_PROXY=

# ===== WhatsApp Bot (whatsapp-web.js) =====
# Intervalo (ms) entre verificações da fila whatsapp_outbox
WA_POLL_INTERVAL_MS=5000
# Diretório onde a sessão é persistida (mantenha em volume Docker pra não escanear QR toda vez)
WA_SESSION_DIR=/app/wa-session
# Endpoint HTTP de controle para restart remoto do WhatsApp
WA_CONTROL_HOST=0.0.0.0
WA_CONTROL_PORT=3011
