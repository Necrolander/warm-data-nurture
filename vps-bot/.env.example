# ===== Lovable Cloud (obrigatório) =====
# URL da edge function ifood-bot-control (não muda)
LOVABLE_FN_URL=https://yxmirlnvrrintrvicqic.supabase.co/functions/v1/ifood-bot-control
# Edge function ingestão de pedidos
LOVABLE_INGEST_URL=https://yxmirlnvrrintrvicqic.supabase.co/functions/v1/external-orders-ingest

# Token compartilhado — MESMO valor que você salvou em IFOOD_BOT_TOKEN no Lovable
BOT_TOKEN=cole_aqui_o_mesmo_token_que_esta_no_lovable

# ===== Comportamento =====
# Intervalo (ms) entre cada checagem de pedidos novos no portal
POLL_INTERVAL_MS=20000
# Headless: true = sem janela visível (produção), false = com navegador (debug local)
HEADLESS=true
# Slow motion (ms) — só pra debug visual
SLOW_MO=0

# ===== iFood Portal =====
IFOOD_PORTAL_URL=https://portal.ifood.com.br

# ===== Proxy (opcional, mas recomendado se IP da VPS estiver bloqueado) =====
# Formato: http://usuario:senha@host:porta  OU  http://host:porta
# Use proxy residencial BRASILEIRO (ex: BrightData, Smartproxy, Oxylabs zona BR)
# Datacenters (DigitalOcean/AWS/Hetzner) costumam ser bloqueados pela Cloudflare do iFood
HTTP_PROXY=
HTTPS_PROXY=

# ===== WhatsApp Sender (envio automático de mensagens) =====
# Acesso direto ao Supabase para consumir a fila whatsapp_outbox
SUPABASE_URL=https://yxmirlnvrrintrvicqic.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_aqui_a_service_role_key
# Intervalo (ms) entre verificações da fila
WA_POLL_INTERVAL_MS=5000
# Na 1ª execução use false para escanear o QR code; depois pode rodar headless=true
WA_HEADLESS=false
